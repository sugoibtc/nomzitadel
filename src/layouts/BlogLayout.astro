---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  date: string;
  category: string;
}

const { title, date, category } = Astro.props;
---

<BaseLayout title={title}>
  <div class="reading-progress fixed top-0 left-0 h-1 bg-mint z-50" id="reading-progress"></div>

  <article class="max-w-3xl mx-auto px-4 py-16">
    <header class="mb-12">
      <span class="inline-block px-3 py-1 text-sm font-medium bg-jade/20 text-mint rounded-full mb-4">
        {category}
      </span>
      <h1 class="text-4xl md:text-5xl font-bold text-white mb-4">{title}</h1>
      <time class="text-pistachio/60">{date}</time>
    </header>

    <div class="prose prose-invert prose-lg max-w-none
      prose-headings:text-white
      prose-p:text-pistachio
      prose-a:text-mint prose-a:no-underline hover:prose-a:text-jade
      prose-strong:text-white
      prose-code:text-mint prose-code:bg-card prose-code:px-2 prose-code:py-1 prose-code:rounded
      prose-pre:bg-card prose-pre:border prose-pre:border-evergreen
      prose-blockquote:border-l-mint prose-blockquote:text-pistachio/80
      prose-li:text-pistachio">
      <slot />
    </div>
  </article>

  <script>
    const progressBar = document.getElementById('reading-progress');

    window.addEventListener('scroll', () => {
      const scrollTop = window.scrollY;
      const docHeight = document.documentElement.scrollHeight - window.innerHeight;
      const progress = (scrollTop / docHeight) * 100;
      if (progressBar) {
        progressBar.style.width = `${progress}%`;
      }
    });
  </script>
</BaseLayout>
