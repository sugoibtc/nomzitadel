---
import '../styles/global.css';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description?: string;
}

const { title, description = "The definitive resource hub for Zenon Network — Bitcoin-native, feeless, decentralized" } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <!-- Manrope via Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <title>{title} | NoM Zitadel</title>
  </head>
  <body class="min-h-screen flex flex-col text-pistachio">
    <div class="site-bg" aria-hidden="true">
      <div class="site-bg__gradient"></div>
      <div class="site-bg__curves" aria-hidden="true">
        <svg class="site-bg__curves-svg" viewBox="0 0 100 100" preserveAspectRatio="xMidYMid slice" xmlns="http://www.w3.org/2000/svg">
          <defs>
            <filter id="curve-glow" x="-20%" y="-20%" width="140%" height="140%">
              <feGaussianBlur in="SourceGraphic" stdDeviation="0.4" result="blur" />
              <feMerge>
                <feMergeNode in="blur" />
                <feMergeNode in="SourceGraphic" />
              </feMerge>
            </filter>
          </defs>
          <!-- Curved momentum lines: top-left to bottom-right, green-grey -->
          <path class="site-bg__curve" fill="none" stroke="currentColor" stroke-width="0.15" filter="url(#curve-glow)" d="M -5 8 Q 20 25 55 45 T 105 75" />
          <path class="site-bg__curve" fill="none" stroke="currentColor" stroke-width="0.12" filter="url(#curve-glow)" d="M -8 18 Q 15 40 50 58 T 108 92" />
          <path class="site-bg__curve" fill="none" stroke="currentColor" stroke-width="0.14" filter="url(#curve-glow)" d="M -2 2 Q 30 28 60 50 T 102 88" />
          <path class="site-bg__curve" fill="none" stroke="currentColor" stroke-width="0.1" filter="url(#curve-glow)" d="M -10 25 Q 25 45 65 62 T 110 98" />
          <path class="site-bg__curve" fill="none" stroke="currentColor" stroke-width="0.13" filter="url(#curve-glow)" d="M 0 15 Q 35 35 70 55 T 105 85" />
          <path class="site-bg__curve" fill="none" stroke="currentColor" stroke-width="0.11" filter="url(#curve-glow)" d="M -6 32 Q 18 52 58 68 T 108 95" />
        </svg>
      </div>
      <div class="site-bg__motion">
        <div class="site-bg__lines"></div>
        <div class="site-bg__particles"></div>
        <div class="site-bg__flow" aria-hidden="true">
          <div class="flow-stream"></div>
        </div>
      </div>
    </div>
    <div class="relative z-10 flex flex-col min-h-screen">
      <Navbar />
      <main class="flex-grow">
        <slot />
      </main>
      <Footer />
    </div>
  </body>
</html>
