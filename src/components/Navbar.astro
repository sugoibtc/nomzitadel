---
import { Image } from 'astro:assets';
import logo from '../assets/logo.jpg';

const navLinks = [
  { href: '/learn', label: 'Learn' },
  { href: '/community', label: 'Community' },
  { href: '/research', label: 'Research' },
  { href: '/build', label: 'Build' },
  { href: '/blog', label: 'Blog' },
];
---

<nav class="sticky top-0 z-40 bg-bg/80 backdrop-blur-md border-b border-evergreen/50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">
      <a href="/" class="flex items-center gap-3 hover:opacity-80 transition-opacity">
        <Image src={logo} alt="Zitadel Logz" class="w-10 h-10 rounded-full" />
        <span class="font-bold text-white text-lg hidden sm:block">Zitadel Logz</span>
      </a>

      <div class="hidden md:flex items-center gap-8">
        {navLinks.map((link) => (
          <a
            href={link.href}
            class="text-pistachio hover:text-mint transition-colors font-medium"
          >
            {link.label}
          </a>
        ))}
      </div>

      <button
        id="mobile-menu-button"
        class="md:hidden p-2 text-pistachio hover:text-mint"
        aria-label="Toggle menu"
      >
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>
  </div>

  <div id="mobile-menu" class="hidden md:hidden bg-card border-b border-evergreen">
    <div class="px-4 py-4 space-y-3">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class="block text-pistachio hover:text-mint transition-colors font-medium py-2"
        >
          {link.label}
        </a>
      ))}
    </div>
  </div>
</nav>

<script>
  const button = document.getElementById('mobile-menu-button');
  const menu = document.getElementById('mobile-menu');

  button?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
  });
</script>
