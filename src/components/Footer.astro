---
import { Image } from 'astro:assets';
import logo from '../assets/logo.jpg';

const navColumns = [
  {
    title: 'Learn',
    links: [
      { href: '/learn', label: 'Overview' },
      { href: '/learn/beginners', label: 'Beginners Guide' },
      { href: '/learn/architecture', label: 'Architecture' },
      { href: '/learn/bitcoin', label: 'Bitcoin + Zenon' },
      { href: '/learn/tokenomics', label: 'Tokenomics' },
    ],
  },
  {
    title: 'Community',
    links: [
      { href: '/community', label: 'Overview' },
      { href: 'https://forum.hypercore.one', label: 'HC1 Forum' },
      { href: 'https://t.me/zenonnetwork', label: 'Telegram' },
    ],
  },
  {
    title: 'Build',
    links: [
      { href: '/build', label: 'Overview' },
      { href: '/research', label: 'Research' },
      { href: 'https://github.com/zenon-network', label: 'GitHub' },
    ],
  },
];
---

<footer class="bg-card border-t border-evergreen mt-auto">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-5 gap-8">
      <div class="lg:col-span-2">
        <a href="/" class="flex items-center gap-3 mb-4">
          <Image src={logo} alt="Zitadel Logz" class="w-12 h-12 rounded-full" />
          <span class="font-bold text-white text-xl">Zitadel Logz</span>
        </a>
        <p class="text-pistachio/70 mb-6 max-w-sm">
          The definitive resource hub for Zenon Network — Bitcoin-native, feeless, decentralized.
        </p>
        <div class="flex items-center gap-4">
          <a
            href="https://x.com/NoMzitadel"
            target="_blank"
            rel="noopener noreferrer"
            class="text-pistachio hover:text-mint transition-colors"
            aria-label="Follow on X"
          >
            <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
              <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
            </svg>
          </a>
          <a
            href="https://t.me/Zitadel"
            target="_blank"
            rel="noopener noreferrer"
            class="text-pistachio hover:text-mint transition-colors"
            aria-label="Join Telegram"
          >
            <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
              <path d="M11.944 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0a12 12 0 0 0-.056 0zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 0 1 .171.325c.016.093.036.306.02.472-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.48.33-.913.49-1.302.48-.428-.008-1.252-.241-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z"/>
            </svg>
          </a>
        </div>
      </div>

      {navColumns.map((column) => (
        <div>
          <h3 class="font-semibold text-white mb-4">{column.title}</h3>
          <ul class="space-y-2">
            {column.links.map((link) => (
              <li>
                <a
                  href={link.href}
                  class="text-pistachio/70 hover:text-mint transition-colors"
                  target={link.href.startsWith('http') ? '_blank' : undefined}
                  rel={link.href.startsWith('http') ? 'noopener noreferrer' : undefined}
                >
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <div class="border-t border-evergreen mt-12 pt-8 text-center text-pistachio/50 text-sm">
      <p>&copy; {new Date().getFullYear()} Zitadel Logz. All rights reserved.</p>
    </div>
  </div>
</footer>
