---
interface Props {
  items: string[];
}

const { items } = Astro.props;
---

<div class="bg-card border-l-4 border-mint rounded-r-xl p-6 my-8">
  <h4 class="text-lg font-semibold text-white mb-4">Key Takeaways</h4>
  <ul class="space-y-2">
    {items.map((item) => (
      <li class="flex items-start gap-3 text-pistachio">
        <span class="text-mint mt-1">&#x2022;</span>
        <span>{item}</span>
      </li>
    ))}
  </ul>
</div>
