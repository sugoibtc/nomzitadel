---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Build">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="max-w-3xl mb-12">
      <h1 class="text-4xl md:text-5xl font-bold text-white mb-6">Build on Zenon</h1>
      <p class="text-xl text-pistachio/80">
        Everything you need to start building on the Network of Momentum — SDKs, documentation, and funding.
      </p>
    </div>

    <!-- GitHub Repos -->
    <section class="mb-16">
      <h2 class="text-2xl font-bold text-white mb-6">GitHub Repositories</h2>
      <a
        href="https://github.com/zenon-network"
        target="_blank"
        rel="noopener noreferrer"
        class="block bg-card border border-evergreen rounded-xl p-6 hover:border-mint transition-colors"
      >
        <div class="flex items-start gap-4">
          <div class="text-4xl">🐙</div>
          <div>
            <h3 class="text-xl font-semibold text-white mb-2">zenon-network</h3>
            <p class="text-pistachio/70 mb-4">
              The official Zenon Network GitHub organization. Contains core protocol implementations, node software, wallets, and tooling.
            </p>
            <span class="text-mint font-medium">Browse repositories →</span>
          </div>
        </div>
      </a>
    </section>

    <!-- TypeScript SDK -->
    <section class="mb-16">
      <h2 class="text-2xl font-bold text-white mb-6">SDKs</h2>
      <a
        href="https://github.com/digitalSloth/znn-typescript-sdk"
        target="_blank"
        rel="noopener noreferrer"
        class="block bg-card border border-evergreen rounded-xl p-6 hover:border-mint transition-colors"
      >
        <div class="flex items-start gap-4">
          <div class="text-4xl">🔷</div>
          <div>
            <h3 class="text-xl font-semibold text-white mb-2">TypeScript SDK</h3>
            <span class="inline-block px-2 py-1 text-xs font-medium bg-mint/20 text-mint rounded mb-3">Feature Complete Beta</span>
            <p class="text-pistachio/70 mb-4">
              A complete TypeScript/JavaScript SDK for interacting with the Zenon Network. Build web apps, Node.js services, or browser extensions.
            </p>
            <span class="text-mint font-medium">View on GitHub →</span>
          </div>
        </div>
      </a>
    </section>

    <!-- AZ Funding -->
    <section class="mb-16">
      <h2 class="text-2xl font-bold text-white mb-6">Accelerator-Z Funding</h2>
      <a
        href="https://accelerator.zenon.network"
        target="_blank"
        rel="noopener noreferrer"
        class="block bg-card border border-evergreen rounded-xl p-6 hover:border-mint transition-colors"
      >
        <div class="flex items-start gap-4">
          <div class="text-4xl">🚀</div>
          <div>
            <h3 class="text-xl font-semibold text-white mb-2">Accelerator-Z</h3>
            <p class="text-pistachio/70 mb-4">
              Apply for funding to build on Zenon. Accelerator-Z provides ZNN and QSR grants to developers, researchers, and community projects that advance the network.
            </p>
            <span class="text-mint font-medium">Apply for funding →</span>
          </div>
        </div>
      </a>
    </section>

    <!-- Developer Tools -->
    <section>
      <h2 class="text-2xl font-bold text-white mb-6">Developer Tools</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        <div class="bg-card border border-evergreen rounded-xl p-6">
          <div class="text-3xl mb-3">🔗</div>
          <h3 class="text-lg font-semibold text-white mb-2">RPC Endpoints</h3>
          <p class="text-pistachio/70 text-sm">Connect to public nodes or run your own for development.</p>
        </div>
        <div class="bg-card border border-evergreen rounded-xl p-6">
          <div class="text-3xl mb-3">🔍</div>
          <h3 class="text-lg font-semibold text-white mb-2">Block Explorers</h3>
          <p class="text-pistachio/70 text-sm">Track transactions, addresses, and network activity.</p>
        </div>
        <div class="bg-card border border-evergreen rounded-xl p-6">
          <div class="text-3xl mb-3">🧪</div>
          <h3 class="text-lg font-semibold text-white mb-2">Testnet</h3>
          <p class="text-pistachio/70 text-sm">Test your applications without real tokens.</p>
        </div>
        <div class="bg-card border border-evergreen rounded-xl p-6">
          <div class="text-3xl mb-3">📚</div>
          <h3 class="text-lg font-semibold text-white mb-2">Documentation</h3>
          <p class="text-pistachio/70 text-sm">API references, guides, and tutorials.</p>
        </div>
        <div class="bg-card border border-evergreen rounded-xl p-6">
          <div class="text-3xl mb-3">💬</div>
          <h3 class="text-lg font-semibold text-white mb-2">Developer Chat</h3>
          <p class="text-pistachio/70 text-sm">Get help from other developers in the community.</p>
        </div>
        <div class="bg-card border border-evergreen rounded-xl p-6">
          <div class="text-3xl mb-3">🛠</div>
          <h3 class="text-lg font-semibold text-white mb-2">CLI Tools</h3>
          <p class="text-pistachio/70 text-sm">Command-line utilities for development and testing.</p>
        </div>
      </div>
    </section>
  </div>
</BaseLayout>
