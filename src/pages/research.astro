---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Research">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="max-w-3xl mb-12">
      <h1 class="text-4xl md:text-5xl font-bold text-white mb-6">Research</h1>
      <p class="text-xl text-pistachio/80">
        Academic papers, technical documentation, and research publications about Zenon Network.
      </p>
    </div>

    <!-- Core Papers -->
    <section class="mb-16">
      <h2 class="text-2xl font-bold text-white mb-6">Core Papers</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <a
          href="https://zenon.network/#downloads"
          target="_blank"
          rel="noopener noreferrer"
          class="block bg-card border border-evergreen rounded-xl p-6 hover:border-mint transition-colors"
        >
          <div class="flex items-start gap-4">
            <div class="text-4xl">📄</div>
            <div>
              <h3 class="text-xl font-semibold text-white mb-2">Zenon Whitepaper</h3>
              <p class="text-pistachio/70 mb-4">
                The foundational document describing Zenon's vision, architecture, and technical design.
              </p>
              <span class="text-mint font-medium">Read on zenon.network →</span>
            </div>
          </div>
        </a>
        <a
          href="https://zenon.network/#downloads"
          target="_blank"
          rel="noopener noreferrer"
          class="block bg-card border border-evergreen rounded-xl p-6 hover:border-mint transition-colors"
        >
          <div class="flex items-start gap-4">
            <div class="text-4xl">📋</div>
            <div>
              <h3 class="text-xl font-semibold text-white mb-2">Zenon Lightpaper</h3>
              <p class="text-pistachio/70 mb-4">
                A condensed overview of Zenon for those who want the key concepts without the deep technical dive.
              </p>
              <span class="text-mint font-medium">Read on zenon.network →</span>
            </div>
          </div>
        </a>
      </div>
    </section>

    <!-- T-Z Research Papers -->
    <section class="mb-16">
      <h2 class="text-2xl font-bold text-white mb-6">T-Z Research Papers</h2>
      <div class="bg-card border border-evergreen rounded-xl p-8 text-center">
        <div class="text-5xl mb-4">🔬</div>
        <h3 class="text-xl font-semibold text-white mb-2">Coming Soon</h3>
        <p class="text-pistachio/70 max-w-md mx-auto">
          In-depth research papers exploring advanced topics in Zenon's architecture, consensus mechanisms, and cryptographic innovations.
        </p>
      </div>
    </section>

    <!-- Community Publications -->
    <section>
      <h2 class="text-2xl font-bold text-white mb-6">Community Publications</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <div class="bg-card border border-evergreen rounded-xl p-6">
          <div class="text-3xl mb-3">📝</div>
          <h3 class="text-lg font-semibold text-white mb-2">Community Article 1</h3>
          <p class="text-pistachio/70 text-sm">Placeholder for community-written research and analysis.</p>
        </div>
        <div class="bg-card border border-evergreen rounded-xl p-6">
          <div class="text-3xl mb-3">📝</div>
          <h3 class="text-lg font-semibold text-white mb-2">Community Article 2</h3>
          <p class="text-pistachio/70 text-sm">Placeholder for community-written research and analysis.</p>
        </div>
        <div class="bg-card border border-evergreen rounded-xl p-6">
          <div class="text-3xl mb-3">📝</div>
          <h3 class="text-lg font-semibold text-white mb-2">Community Article 3</h3>
          <p class="text-pistachio/70 text-sm">Placeholder for community-written research and analysis.</p>
        </div>
      </div>
    </section>
  </div>
</BaseLayout>
