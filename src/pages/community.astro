---
import BaseLayout from '../layouts/BaseLayout.astro';

const kols = [
  { name: 'Community Builder 1', handle: '@builder1', description: 'Long-time contributor and educator' },
  { name: 'Community Builder 2', handle: '@builder2', description: 'Technical researcher and writer' },
  { name: 'Community Builder 3', handle: '@builder3', description: 'Developer and community organizer' },
];
---

<BaseLayout title="Community">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="max-w-3xl mb-12">
      <h1 class="text-4xl md:text-5xl font-bold text-white mb-6">Community</h1>
      <p class="text-xl text-pistachio/80">
        Zenon is built by its community. No company, no marketing team — just builders, researchers, and enthusiasts working together.
      </p>
    </div>

    <!-- HC1 Forum -->
    <section class="mb-16">
      <h2 class="text-2xl font-bold text-white mb-6">HC1 Forum</h2>
      <a
        href="https://forum.hypercore.one"
        target="_blank"
        rel="noopener noreferrer"
        class="block bg-card border border-evergreen rounded-xl p-6 hover:border-mint transition-colors"
      >
        <div class="flex items-start gap-4">
          <div class="text-4xl">💬</div>
          <div>
            <h3 class="text-xl font-semibold text-white mb-2">Hypercore One Forum</h3>
            <p class="text-pistachio/70 mb-4">
              The main discussion hub for Zenon governance, technical proposals, and community coordination. This is where important decisions are debated and documented.
            </p>
            <span class="text-mint font-medium">Visit forum.hypercore.one →</span>
          </div>
        </div>
      </a>
    </section>

    <!-- Telegram -->
    <section class="mb-16">
      <h2 class="text-2xl font-bold text-white mb-6">Telegram</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <a
          href="https://t.me/zenonnetwork"
          target="_blank"
          rel="noopener noreferrer"
          class="block bg-card border border-evergreen rounded-xl p-6 hover:border-mint transition-colors"
        >
          <div class="flex items-start gap-4">
            <div class="text-4xl">📱</div>
            <div>
              <h3 class="text-xl font-semibold text-white mb-2">Main Zenon Group</h3>
              <p class="text-pistachio/70 mb-4">
                The primary Telegram group for general discussion, news, and community chat.
              </p>
              <span class="text-mint font-medium">Join on Telegram →</span>
            </div>
          </div>
        </a>
        <a
          href="https://t.me/Zitadel"
          target="_blank"
          rel="noopener noreferrer"
          class="block bg-card border border-evergreen rounded-xl p-6 hover:border-mint transition-colors"
        >
          <div class="flex items-start gap-4">
            <div class="text-4xl">🏰</div>
            <div>
              <h3 class="text-xl font-semibold text-white mb-2">Zitadel</h3>
              <p class="text-pistachio/70 mb-4">
                Our Telegram community for deeper discussions and coordination.
              </p>
              <span class="text-mint font-medium">Join Zitadel →</span>
            </div>
          </div>
        </a>
      </div>
    </section>

    <!-- X / Twitter -->
    <section class="mb-16">
      <h2 class="text-2xl font-bold text-white mb-6">X (Twitter)</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <a
          href="https://x.com/NoMzitadel"
          target="_blank"
          rel="noopener noreferrer"
          class="block bg-card border border-evergreen rounded-xl p-6 hover:border-mint transition-colors"
        >
          <div class="flex items-start gap-4">
            <div class="text-4xl">🏰</div>
            <div>
              <h3 class="text-xl font-semibold text-white mb-2">@NoMzitadel</h3>
              <p class="text-pistachio/70 mb-4">
                Zitadel Logz on X — news, updates, and educational content.
              </p>
              <span class="text-mint font-medium">Follow @NoMzitadel →</span>
            </div>
          </div>
        </a>
        <a
          href="https://x.com/sugoibtc"
          target="_blank"
          rel="noopener noreferrer"
          class="block bg-card border border-evergreen rounded-xl p-6 hover:border-mint transition-colors"
        >
          <div class="flex items-start gap-4">
            <div class="text-4xl">🐦</div>
            <div>
              <h3 class="text-xl font-semibold text-white mb-2">@sugoibtc</h3>
              <p class="text-pistachio/70 mb-4">
                Community voice and content creator.
              </p>
              <span class="text-mint font-medium">Follow @sugoibtc →</span>
            </div>
          </div>
        </a>
      </div>
    </section>

    <!-- KOLs to Follow -->
    <section class="mb-16">
      <h2 class="text-2xl font-bold text-white mb-6">KOLs to Follow</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {kols.map((kol) => (
          <div class="bg-card border border-evergreen rounded-xl p-6">
            <h3 class="text-lg font-semibold text-white mb-1">{kol.name}</h3>
            <p class="text-mint text-sm mb-3">{kol.handle}</p>
            <p class="text-pistachio/70 text-sm">{kol.description}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- Outlawz -->
    <section>
      <h2 class="text-2xl font-bold text-white mb-6">Outlawz Community</h2>
      <a
        href="https://znnoutlawz.com"
        target="_blank"
        rel="noopener noreferrer"
        class="block bg-card border border-evergreen rounded-xl p-6 hover:border-mint transition-colors"
      >
        <div class="flex items-start gap-4">
          <div class="text-4xl">🤠</div>
          <div>
            <h3 class="text-xl font-semibold text-white mb-2">ZNN Outlawz</h3>
            <p class="text-pistachio/70 mb-4">
              A community-driven initiative bringing together Zenon enthusiasts with a unique culture and perspective.
            </p>
            <span class="text-mint font-medium">Visit znnoutlawz.com →</span>
          </div>
        </div>
      </a>
    </section>
  </div>
</BaseLayout>
